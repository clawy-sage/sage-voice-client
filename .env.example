# ─────────────────────────────────────────────
#  sage-voice-client — environment configuration
#  Copy this file to .env and fill in your values
#  NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── Porcupine (Wake Word) ────────────────────
# Get a free key at https://picovoice.io
PORCUPINE_ACCESS_KEY=your_porcupine_access_key_here

# Wake word to listen for.
# Built-in options: "jarvis", "hey siri", "alexa", "computer", "porcupine", etc.
# For a custom wake word, set PORCUPINE_KEYWORD_PATH to your .ppn model file instead.
PORCUPINE_KEYWORD=jarvis
# PORCUPINE_KEYWORD_PATH=/path/to/custom_wake_word.ppn

# ── Speech-to-Text (Whisper) ─────────────────
# STT Backend: "api" (OpenAI Whisper) or "local" (faster-whisper, free/offline)
STT_BACKEND=api

# OpenAI Whisper API key (required only when STT_BACKEND=api)
# Get a key at https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Whisper API model to use (when STT_BACKEND=api)
WHISPER_MODEL=whisper-1

# Local Whisper settings (only used when STT_BACKEND=local)
# Model sizes: tiny (~75MB), base (~150MB), small (~500MB), medium (~1.5GB), large-v3 (~3GB)
WHISPER_LOCAL_MODEL=base
# Device: cpu or cuda (if you have an NVIDIA GPU)
WHISPER_LOCAL_DEVICE=cpu
# Compute type: int8 (fast/CPU), float16 (GPU), float32 (accurate/slow)
WHISPER_LOCAL_COMPUTE_TYPE=int8

# How many seconds of silence end the recording
RECORDING_SILENCE_TIMEOUT_SECONDS=2.0

# Maximum recording length in seconds (safety limit)
RECORDING_MAX_SECONDS=30

# ── OpenClaw Agent API ───────────────────────
# Base URL of your OpenClaw gateway
OPENCLAW_BASE_URL=http://localhost:9999

# API token for your OpenClaw instance
OPENCLAW_API_TOKEN=your_openclaw_api_token_here

# Session/channel target (e.g. "main" or a specific session key)
OPENCLAW_SESSION=main

# ── ElevenLabs (TTS) ─────────────────────────
# Get a key at https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID to use for TTS responses
# Find voice IDs at https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# TTS model: eleven_multilingual_v2 or eleven_turbo_v2_5 (faster/cheaper)
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── Audio ────────────────────────────────────
# Input device index (leave empty for system default)
# Run: python -c "import sounddevice; print(sounddevice.query_devices())"
AUDIO_INPUT_DEVICE_INDEX=

# Output device index (leave empty for system default)
AUDIO_OUTPUT_DEVICE_INDEX=

# Sample rate for recording (Hz)
AUDIO_SAMPLE_RATE=16000
